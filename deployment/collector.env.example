APP_ENV=production
LOG_LEVEL=INFO
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@ticker
PROVIDER_CODE=binance_spot
SYMBOL=BTCUSDT
STALE_PRICE_MS=10000
POLYMARKET_RTDS_WS_URL=wss://ws-live-data.polymarket.com
POLYMARKET_CHAINLINK_PROVIDER_CODE=polymarket_chainlink_rtds
POLYMARKET_CHAINLINK_SYMBOL=BTCUSD
POLYMARKET_CHAINLINK_RTD_SYMBOL=btc/usd
POLYMARKET_CHAINLINK_TOPIC=crypto_prices_chainlink
BINANCE_FUTURES_STREAMS_ENABLED=true
BINANCE_FUTURES_AGG_TRADE_WS_URL=wss://fstream.binance.com/market/ws/btcusdt@aggTrade
BINANCE_FUTURES_BOOK_TICKER_WS_URL=wss://fstream.binance.com/public/ws/btcusdt@bookTicker
BINANCE_FUTURES_FLOW_FLUSH_DELAY_MS=1500
BINANCE_FUTURES_BOOK_FLUSH_DELAY_MS=1500
BINANCE_FUTURES_STREAM_FLUSH_SECONDS=0.25
BINANCE_FUTURES_STORE_RAW_JSON=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
DATABASE_URL=postgresql://price_writer:REPLACE_ME@127.0.0.1:5432/price_collector

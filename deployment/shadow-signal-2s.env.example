APP_ENV=production
LOG_LEVEL=INFO

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_SOCKET_TIMEOUT_SECONDS=0.25

# This challenger is intentionally separate from the accepted shadow worker.
SHADOW_SIGNAL_2S_ENABLED=false
SHADOW_SIGNAL_2S_POLL_MS=100
SHADOW_SIGNAL_2S_TTL_MS=2000

# Matured PostgreSQL evidence remains independently opt-in. When enabled,
# add the writer DATABASE_URL manually; never add READ_DATABASE_URL here.
SHADOW_SIGNAL_2S_EVALUATION_ENABLED=false
SHADOW_SIGNAL_2S_EVALUATION_INTERVAL_MS=500
SHADOW_SIGNAL_2S_EVALUATION_QUEUE_MAX=5000
SHADOW_SIGNAL_2S_EVALUATION_BATCH_MAX_ROWS=500
SHADOW_SIGNAL_2S_EVALUATION_FLUSH_MS=1000
SHADOW_SIGNAL_2S_EVALUATION_RETRY_MS=5000
SHADOW_SIGNAL_2S_EVALUATION_SHUTDOWN_TIMEOUT_SECONDS=10
SHADOW_SIGNAL_2S_EVALUATION_DB_CONNECT_TIMEOUT_SECONDS=5
SHADOW_SIGNAL_2S_EVALUATION_DB_COMMAND_TIMEOUT_SECONDS=5
SHADOW_SIGNAL_2S_EVALUATION_RETENTION_HOURS=168
SHADOW_SIGNAL_2S_EVALUATION_RETENTION_CHECK_SECONDS=300
SHADOW_SIGNAL_2S_EVALUATION_RETENTION_BATCH_ROWS=5000
